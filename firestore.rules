rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is admin of this store
    function isAdminOf(storeId) {
      return request.auth != null
        && storeId in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.storeIds;
    }

    // Admins collection: only the user themselves
    match /admins/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Stores: anyone can read (needed for join page), only admin can write
    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdminOf(storeId);

      // Seats subcollection
      match /seats/{seatId} {
        allow read: if true;
        allow write: if isAdminOf(storeId);
      }
    }

    // Queues: anyone can create, read their own; admin can update/manage
    match /queues/{queueId} {
      allow create: if true;
      allow read: if true;
      // Customer can cancel their own; admin can update anything
      allow update: if request.auth != null
        || (resource.data.status == "waiting"
            && request.resource.data.status == "cancelled");
      allow delete: if false;
    }
  }
}
